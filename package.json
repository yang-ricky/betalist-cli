{
	"name": "betalist-cli",
	"version": "0.1.1",
	"description": "Unofficial CLI for BetaList — discover tomorrow's startups, today",
	"type": "module",
	"bin": {
		"betalist": "./dist/index.js",
		"bl": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"fixtures:update": "node scripts/update-html-fixtures.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"pack:check": "npm pack --dry-run",
		"selector:health": "npm run build && node scripts/check-selector-health.mjs",
		"test": "vitest run",
		"test:live": "BL_LIVE_TESTS=1 vitest run tests/integration/html-backend.test.ts",
		"test:watch": "vitest",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yang-ricky/betalist-cli.git"
	},
	"homepage": "https://github.com/yang-ricky/betalist-cli#readme",
	"bugs": {
		"url": "https://github.com/yang-ricky/betalist-cli/issues"
	},
	"keywords": [
		"betalist",
		"startups",
		"cli",
		"terminal",
		"early-stage"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "npm@11.5.1",
	"dependencies": {
		"chalk": "^5.6.2",
		"cheerio": "^1.2.0",
		"cli-table3": "^0.6.5",
		"commander": "^14.0.3",
		"cosmiconfig": "^9.0.1",
		"js-yaml": "^4.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@changesets/cli": "^2.30.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.5.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
